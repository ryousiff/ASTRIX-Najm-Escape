<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score: 00" name="ScoreLabel" style="align-self: center; width: 146px; -unity-font-style: normal; font-size: 15px; -unity-text-align: upper-center; color: rgb(255, 255, 255); top: 17px; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Orbitron-SemiBold.ttf?fileID=12800000&amp;guid=a768d5c8c27af4da99dc1ae0ac668914&amp;type=3#Orbitron-SemiBold&quot;); background-color: rgba(0, 0, 0, 0.47); border-left-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); border-top-color: rgb(255, 255, 255); border-bottom-color: rgb(255, 255, 255); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 7px; border-top-right-radius: 7px; border-bottom-right-radius: 7px; border-bottom-left-radius: 7px; height: 32px;"/>
