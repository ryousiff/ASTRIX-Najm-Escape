        <ui:Button text="Restart" name="RestartButton" style="position: absolute; top: 39%; align-self: center; -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Orbitron-SemiBold.ttf?fileID=12800000&amp;guid=a768d5c8c27af4da99dc1ae0ac668914&amp;type=3#Orbitron-SemiBold&quot;); font-size: 12px; border-top-left-radius: 8px; border-top-right-radius: 8px; border-bottom-right-radius: 8px; border-bottom-left-radius: 8px; border-left-color: rgb(149, 149, 149); border-right-color: rgb(149, 149, 149); border-top-color: rgb(149, 149, 149); border-bottom-color: rgb(149, 149, 149); background-color: rgba(188, 188, 188, 0.48);"/>
